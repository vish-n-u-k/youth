{
  "openapi": "3.1.0",
  "info": {
    "title": "Program & Pricing API",
    "version": "v1.0.0",
    "x-module-id": "program_pricing",
    "x-contract-status": "draft",
    "x-change-type": "none"
  },
  "paths": {
    "/api/programs": {
      "get": {
        "operationId": "getPrograms",
        "summary": "List programs with optional status filter and pagination",
        "tags": ["programs"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["draft", "active", "closed"] } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated program list",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramListResponse" } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      },
      "post": {
        "operationId": "createProgram",
        "summary": "Create a new program",
        "tags": ["programs"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramRequest" } } }
        },
        "responses": {
          "201": {
            "description": "Program created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramResponse" } } }
          },
          "400": { "description": "Validation error (e.g. max age < min age)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/api/programs/{programId}": {
      "get": {
        "operationId": "getProgram",
        "summary": "Get single program details",
        "tags": ["programs"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "programId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Program details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramResponse" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "404": { "description": "Program not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      },
      "put": {
        "operationId": "updateProgram",
        "summary": "Update an existing program",
        "tags": ["programs"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "programId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramRequest" } } }
        },
        "responses": {
          "200": { "description": "Program updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "404": { "description": "Program not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/api/coupons": {
      "get": {
        "operationId": "getCoupons",
        "summary": "List all coupons",
        "tags": ["coupons"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Coupon list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CouponListResponse" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      },
      "post": {
        "operationId": "createCoupon",
        "summary": "Create a new coupon",
        "tags": ["coupons"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CouponRequest" } } }
        },
        "responses": {
          "201": { "description": "Coupon created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CouponResponse" } } } },
          "400": { "description": "Validation error (e.g. duplicate code)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "409": { "description": "Coupon code already exists", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/api/coupons/{couponId}": {
      "put": {
        "operationId": "updateCoupon",
        "summary": "Update an existing coupon",
        "tags": ["coupons"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "couponId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CouponRequest" } } }
        },
        "responses": {
          "200": { "description": "Coupon updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CouponResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "404": { "description": "Coupon not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      },
      "delete": {
        "operationId": "deleteCoupon",
        "summary": "Delete a coupon",
        "tags": ["coupons"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "couponId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Coupon deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DeleteResponse" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "404": { "description": "Coupon not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProgramListResponse": {
        "type": "object",
        "required": ["programs", "total", "page", "limit"],
        "properties": {
          "programs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["programId", "name", "ageGroupMin", "ageGroupMax", "startDate", "endDate", "enrollmentCount", "capacity", "status", "totalFee"],
              "properties": {
                "programId": { "type": "string" },
                "name": { "type": "string" },
                "ageGroupMin": { "type": "integer" },
                "ageGroupMax": { "type": "integer" },
                "startDate": { "type": "string", "format": "date-time" },
                "endDate": { "type": "string", "format": "date-time" },
                "enrollmentCount": { "type": "integer" },
                "capacity": { "type": "integer" },
                "status": { "type": "string", "enum": ["draft", "active", "closed"] },
                "totalFee": { "type": "number" }
              }
            }
          },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "limit": { "type": "integer" }
        },
        "x-zod-schema": "ProgramListResponse"
      },
      "ProgramResponse": {
        "type": "object",
        "required": ["programId", "name", "ageGroupMin", "ageGroupMax", "totalSessions", "sessionDuration", "location", "startDate", "endDate", "capacity", "status", "baseFee", "feeType", "totalFee", "registrationFeeRequired", "trialAvailable", "locationId", "enrollmentCount", "createdAt", "updatedAt"],
        "properties": {
          "programId": { "type": "string" },
          "name": { "type": "string" },
          "ageGroupMin": { "type": "integer" },
          "ageGroupMax": { "type": "integer" },
          "totalSessions": { "type": "integer" },
          "sessionDuration": { "type": "number" },
          "location": { "type": "string" },
          "startDate": { "type": "string", "format": "date-time" },
          "endDate": { "type": "string", "format": "date-time" },
          "capacity": { "type": "integer" },
          "status": { "type": "string", "enum": ["draft", "active", "closed"] },
          "baseFee": { "type": "number" },
          "feeType": { "type": "string", "enum": ["total", "per_session"] },
          "totalFee": { "type": "number", "description": "Computed: baseFee if feeType=total, baseFee*totalSessions if per_session" },
          "registrationFee": { "type": "number", "nullable": true },
          "registrationFeeRequired": { "type": "boolean" },
          "trialAvailable": { "type": "boolean" },
          "locationId": { "type": "string" },
          "enrollmentCount": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "x-zod-schema": "ProgramResponse"
      },
      "ProgramRequest": {
        "type": "object",
        "required": ["name", "ageGroupMin", "ageGroupMax", "totalSessions", "sessionDuration", "location", "startDate", "endDate", "capacity", "status", "baseFee", "feeType", "registrationFeeRequired", "trialAvailable"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "ageGroupMin": { "type": "integer", "minimum": 0 },
          "ageGroupMax": { "type": "integer", "minimum": 0 },
          "totalSessions": { "type": "integer", "minimum": 1 },
          "sessionDuration": { "type": "number", "minimum": 1 },
          "location": { "type": "string", "minLength": 1 },
          "startDate": { "type": "string", "format": "date-time" },
          "endDate": { "type": "string", "format": "date-time" },
          "capacity": { "type": "integer", "minimum": 1 },
          "status": { "type": "string", "enum": ["draft", "active", "closed"] },
          "baseFee": { "type": "number", "minimum": 0 },
          "feeType": { "type": "string", "enum": ["total", "per_session"] },
          "registrationFee": { "type": "number", "minimum": 0 },
          "registrationFeeRequired": { "type": "boolean" },
          "trialAvailable": { "type": "boolean" }
        },
        "x-zod-schema": "ProgramRequest",
        "x-validation": "ageGroupMax must be >= ageGroupMin"
      },
      "CouponListResponse": {
        "type": "object",
        "required": ["coupons"],
        "properties": {
          "coupons": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CouponResponse" }
          }
        },
        "x-zod-schema": "CouponListResponse"
      },
      "CouponRequest": {
        "type": "object",
        "required": ["code", "discountType", "discountValue", "scope"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "discountType": { "type": "string", "enum": ["percentage", "flat"] },
          "discountValue": { "type": "number", "minimum": 0 },
          "scope": { "type": "string", "enum": ["program_fee", "registration_fee", "both"] },
          "expiresAt": { "type": "string", "format": "date-time" },
          "usageLimit": { "type": "integer", "minimum": 1 }
        },
        "x-zod-schema": "CouponRequest"
      },
      "CouponResponse": {
        "type": "object",
        "required": ["couponId", "code", "discountType", "discountValue", "scope", "usageCount", "createdAt"],
        "properties": {
          "couponId": { "type": "string" },
          "code": { "type": "string" },
          "discountType": { "type": "string", "enum": ["percentage", "flat"] },
          "discountValue": { "type": "number" },
          "scope": { "type": "string", "enum": ["program_fee", "registration_fee", "both"] },
          "expiresAt": { "type": "string", "format": "date-time", "nullable": true },
          "usageLimit": { "type": "integer", "nullable": true },
          "usageCount": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "x-zod-schema": "CouponResponse"
      },
      "DeleteResponse": {
        "type": "object",
        "required": ["message", "deleted"],
        "properties": {
          "message": { "type": "string" },
          "deleted": { "type": "boolean" }
        },
        "x-zod-schema": "DeleteResponse"
      },
      "ApiError": {
        "type": "object",
        "required": ["error", "message", "statusCode"],
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" },
          "statusCode": { "type": "integer" }
        },
        "x-zod-schema": "ApiError"
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session"
      }
    }
  }
}
