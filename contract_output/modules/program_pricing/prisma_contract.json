  "enumDefs": [
    {
      "name": "ProgramStatus",
      "values": ["DRAFT", "ACTIVE", "CLOSED"],
      "volatilityClassification": "stable",
      "reason": "Lifecycle states (draft/active/closed) are workflow-defined. Changes require business process redesign."
    },
    {
      "name": "FeeType",
      "values": ["TOTAL", "PER_SESSION"],
      "volatilityClassification": "stable",
      "reason": "Pricing models are structurally different. Adding new types requires pricing engine changes."
    },
    {
      "name": "DiscountType",
      "values": ["PERCENTAGE", "FLAT"],
      "volatilityClassification": "stable",
      "reason": "Standard discount calculation types. Adding a new type requires calculation logic changes."
    },
    {
      "name": "CouponScope",
      "values": ["PROGRAM_FEE", "REGISTRATION_FEE", "BOTH"],
      "volatilityClassification": "stable",
      "reason": "Scope maps to the two fee components in the pricing model. Stable unless fee structure changes."
    }
  ],
  "dbNotes": {
    "computedFields": "enrollmentCount and totalFee are computed at query time, not stored. enrollmentCount = COUNT(Enrollment WHERE programId AND status=ACTIVE). totalFee = baseFee if TOTAL, else baseFee * totalSessions.",
    "capacityModel": "A-12/PP-A-02: Capacity is per-program (not per-session). Pending human review but proceeding as default. Capacity field is at program level; keep isolated for future per-session migration.",
    "couponUniqueness": "Coupon code uniqueness enforced at DB level. 409 Conflict returned on duplicate (GF-10).",
    "couponBelowZero": "PP-BR-02: Coupons cannot reduce total below zero. Enforced at application level, not DB constraint.",
    "publishPrerequisite": "PP-BR-04/ST-BR-01: Only ACTIVE programs visible to parents. Zelle config must exist before program can be set to ACTIVE. Application-level check."
  }
