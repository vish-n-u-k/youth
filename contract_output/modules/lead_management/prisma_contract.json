  "enumDefs": [
    {
      "name": "LeadSource",
      "values": ["FACEBOOK", "GOOGLE", "WEBSITE", "MANUAL"],
      "volatilityClassification": "stable",
      "reason": "Lead sources are integration-specific. Adding a new source requires new integration code. Not admin-manageable."
    },
    {
      "name": "LeadStatus",
      "values": ["NEW", "CONTACTED", "TRIAL_SCHEDULED", "TRIAL_ATTENDED", "ENROLLED", "DROPPED", "NOT_INTERESTED"],
      "volatilityClassification": "stable",
      "reason": "Lifecycle states are fixed by business workflow (LM-BR-04). Changes require workflow redesign, not admin configuration."
    },
    {
      "name": "ActivityType",
      "values": ["STATUS_CHANGE", "EMAIL_SENT", "ENROLLMENT_EVENT", "NOTE_ADDED", "LEAD_CREATED"],
      "volatilityClassification": "stable",
      "reason": "Activity types map to system events. New types require new code paths."
    }
  ],
  "dbNotes": {
    "emailUniqueness": "A-01/LM-A-01: Returning parents identified by email match. Email is unique constraint — different email = new lead. Pending human review but proceeding as default.",
    "leadAutoAdvance": "GP-04/LM-BR-02: Lead status auto-advances on enrollment events (trial booked → TRIAL_SCHEDULED, enrolled → ENROLLED). Admin can always manually override.",
    "immutableRecords": "LeadNote and LeadActivity are append-only (no update/delete). They serve as audit trail.",
    "cascadeDelete": "Deleting a Lead cascades to LeadNote and LeadActivity records.",
    "noCreateEndpoint": "LM-BF-01: No POST /api/leads endpoint for manual lead creation in current FE contract. Lead records are created via enrollment/trial flows or external integrations."
  }
