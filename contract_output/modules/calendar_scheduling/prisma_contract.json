  "dbNotes": {
    "computedFields": "spotsRemaining is computed at query time: capacity - COUNT(Trial WHERE trialDateId AND status != CANCELLED). programName is joined from Program.name at query time. Neither is stored.",
    "dateUniqueness": "No duplicate class dates for the same program. Enforced by unique constraint on (programId, date).",
    "hardDelete": "Current API supports DELETE /api/calendar/:dateId. Hard delete is acceptable since trial bookings reference by trialDateId FK — deletion will fail if trials reference the date (FK constraint prevents orphans).",
    "trialDates": "CS-A-01/A-11: Trial bookings require selecting from admin-defined trial-eligible dates. Parent-facing endpoint filters by trialEligible=true AND date >= now AND spotsRemaining > 0.",
