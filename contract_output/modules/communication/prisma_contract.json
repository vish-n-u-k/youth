  "enumDefs": [
    {
      "name": "TriggerEvent",
      "values": [
        "LEAD_CREATED",
        "TRIAL_SCHEDULED",
        "TRIAL_APPROACHING",
        "ENROLLMENT_COMPLETED",
        "PAYMENT_OVERDUE",
        "CLASS_START_APPROACHING"
      ],
      "volatilityClassification": "stable",
      "reason": "Trigger events map to system events requiring code changes to add. 6 fixed triggers with pre-created automations."
    },
    {
      "name": "DeliveryStatus",
      "values": ["PENDING", "SENT", "FAILED"],
      "volatilityClassification": "stable",
      "reason": "Standard email delivery lifecycle. Adding SMS/WhatsApp in Phase 2 would reuse same statuses."
    }
  ],
  "dbNotes": {
    "defaultTemplates": "CM-A-01: 6 default templates are pre-created via seed data. Editable but not deletable (isDefault=true protected at application level).",
    "automationSeeds": "6 automation rows pre-created (one per TriggerEvent). No CREATE/DELETE endpoints — only UPDATE to change template, delay, or enabled status.",
    "logImmutability": "CommunicationLog is append-only (no update/delete). Each send attempt creates a new entry. Retry creates a new log entry, does not update existing.",
    "noForeignKeysOnLog": "CommunicationLog intentionally has no FK to Template or Automation. It stores snapshot data (templateName, subject with variables interpolated) for audit independence.",
    "emailOnly": "CM-A-02 (user approved): Email only in MVP. Channel abstraction for SMS/WhatsApp is Phase 2. No channel field needed yet.",
    "variablePlaceholders": "Template body stores {{variable_name}} placeholders. availableVariables array in API response is derived by parsing body at query time, not stored.",
    "handoffs": "HO-03: Trial/enrollment → email triggers. HO-04: Payment overdue → reminder email. Both fire via automation engine, not direct API calls."
  }
