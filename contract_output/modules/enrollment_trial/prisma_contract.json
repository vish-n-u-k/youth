  "enumDefs": [
    {
      "name": "TrialStatus",
      "values": ["SCHEDULED", "COMPLETED", "NO_SHOW", "CANCELLED"],
      "volatilityClassification": "stable",
      "reason": "Trial lifecycle states are fixed by business workflow. Changes require process redesign."
    },
    {
      "name": "EnrollmentStatus",
      "values": ["ACTIVE", "CANCELLED", "COMPLETED"],
      "volatilityClassification": "stable",
      "reason": "Core enrollment lifecycle. ET-A-02 confirmed instant enrollment for MVP. Future 'PENDING_APPROVAL' would be a code change."
    }
  ],
  "dbNotes": {
    "instantEnrollment": "ET-A-02 (user approved): Enrollment is instant on submission. No approval workflow. Admin can cancel after the fact via PATCH status.",
    "onePerChild": "GP-01: One enrollment per child per program. Application-level enforcement — check (childName + childAge + programId) before creating. Not a DB unique constraint because childName/Age is not a reliable unique identifier.",
    "trialIdUnique": "trialId on Enrollment is unique (nullable) — one-to-one optional relationship. An enrollment may or may not have originated from a trial.",
    "leadAutoCreation": "GP-02/GP-04: On enrollment/trial submission, if parentEmail matches existing Lead, link to it. Otherwise create new Lead. Lead status auto-advances.",
    "priceSnapshot": "priceBreakdown stored as JSON snapshot at enrollment time. Captures itemized fees at the point of enrollment, independent of later program price changes.",
    "noWaitlist": "ET-A-04: No waitlist in MVP. Full program returns 409 Conflict. Admin can manually override.",
    "handoffs": "HO-01: Lead → Trial booking. HO-02: Enrollment → Payment creation. HO-03: Trial/Enrollment → confirmation emails.",
    "denormalizedParent": "parentName, parentEmail, parentPhone stored on both Trial and Enrollment. Lead is the authoritative source, but denormalization ensures public forms work without lead lookup.",
    "cancellationReason": "Required when status transitions to CANCELLED. Application-level validation."
  }
