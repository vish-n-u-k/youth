{
  "openapi": "3.1.0",
  "info": {
    "title": "Youth Platform Unified API",
    "version": "1.0.0",
    "description": "Canonical unified API contract for the Youth Platform. Single source of truth for all BE endpoints across all modules.",
    "x-generated-by": "be-agent",
    "x-generated-at": "2026-03-08T00:00:00Z",
    "x-status": "all_modules_complete",
