  "paths": {
    "/api/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Platform health check",
        "tags": ["platform"],
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["status", "timestamp"],
                  "properties": {
                    "status": { "type": "string", "enum": ["ok"] },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "operationId": "adminLogin",
        "summary": "Admin login with email and password",
        "tags": ["auth_accounts"],
        "security": [],
        "x-rate-limit": "auth_login",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminLoginRequest" } } }
        },
        "responses": {
          "200": { "description": "Login successful. Session cookie set.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminLoginResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "operationId": "adminLogout",
        "summary": "Admin logout — clears session",
        "tags": ["auth_accounts"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Logout successful", "content": { "application/json": { "schema": { "type": "object", "required": ["message"], "properties": { "message": { "type": "string" } } } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "operationId": "getSession",
        "summary": "Validate current session and return logged-in user",
        "tags": ["auth_accounts"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Session is valid", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminLoginResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "operationId": "requestPasswordReset",
        "summary": "Request a password reset link via email",
        "tags": ["auth_accounts"],
        "security": [],
        "x-rate-limit": "auth_recovery",
        "x-security-note": "Always returns success regardless of email existence (AA-A-03)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordResetRequest" } } }
        },
        "responses": {
          "200": { "description": "Reset link sent (same response whether email exists or not)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "429": { "$ref": "#/components/responses/TooManyRequests" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "operationId": "setNewPassword",
        "summary": "Set a new password using a reset token",
        "tags": ["auth_accounts"],
        "security": [],
        "x-rate-limit": "auth_reset",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SetNewPasswordRequest" } } }
        },
        "responses": {
          "200": { "description": "Password updated successfully", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Invalid token or validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "410": { "description": "Reset link expired (24h TTL)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/settings": {
      "get": {
        "operationId": "getSettings",
        "summary": "Get current location settings",
        "tags": ["settings"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Current settings", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SettingsResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "put": {
        "operationId": "updateSettings",
        "summary": "Update location settings",
        "tags": ["settings"],
        "security": [{ "cookieAuth": [] }],
        "x-idempotency": "idempotent",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateSettingsRequest" } } }
        },
        "responses": {
          "200": { "description": "Settings updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SettingsResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/communications/templates": {
      "get": {
        "operationId": "getTemplates",
        "summary": "List all email templates",
        "tags": ["communication"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Template list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TemplateListResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "post": {
        "operationId": "createTemplate",
        "summary": "Create a custom email template",
        "tags": ["communication"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TemplateRequest" } } }
        },
        "responses": {
          "201": { "description": "Template created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TemplateResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/communications/templates/{templateId}": {
      "get": {
        "operationId": "getTemplate",
        "summary": "Get single template with body and available variables",
        "tags": ["communication"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "templateId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Template details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TemplateResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "put": {
        "operationId": "updateTemplate",
        "summary": "Update an email template",
        "tags": ["communication"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "templateId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TemplateRequest" } } }
        },
        "responses": {
          "200": { "description": "Template updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TemplateResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/communications/automations": {
      "get": {
        "operationId": "getAutomations",
        "summary": "List all automation rules",
        "tags": ["communication"],
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Automation rules list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AutomationListResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/communications/automations/{automationId}": {
      "put": {
        "operationId": "updateAutomation",
        "summary": "Update an automation rule (template, delay, enable/disable)",
        "tags": ["communication"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "automationId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AutomationRequest" } } }
        },
        "responses": {
          "200": { "description": "Automation updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AutomationResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/communications/log": {
      "get": {
        "operationId": "getCommunicationsLog",
        "summary": "View sent/failed/pending email log with filters and pagination",
        "tags": ["communication"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "deliveryStatus", "in": "query", "schema": { "type": "string", "enum": ["sent", "failed", "pending"] } },
          { "name": "triggerEvent", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "description": "Search by recipient name or email", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 } }
        ],
        "responses": {
          "200": { "description": "Communications log", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommunicationsLogResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/api/communications/log/{logId}/retry": {
      "post": {
        "operationId": "retryEmail",
        "summary": "Retry sending a failed email",
        "tags": ["communication"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "logId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Retry queued", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RetryEmailResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "description": "Email already sent or retry already queued", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    }
