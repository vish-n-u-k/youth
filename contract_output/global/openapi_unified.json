      "AutomationRequest": {
        "type": "object",
        "required": ["triggerEvent", "templateId", "enabled"],
        "properties": {
          "triggerEvent": { "type": "string", "enum": ["lead_created", "trial_scheduled", "trial_approaching", "enrollment_completed", "payment_overdue", "class_start_approaching"] },
          "templateId": { "type": "string" },
          "delayMinutes": { "type": "integer", "minimum": 0 },
          "enabled": { "type": "boolean" }
        },
        "x-zod-schema": "AutomationRequest"
      },
      "AutomationResponse": {
        "type": "object",
        "required": ["automationId", "triggerEvent", "templateId", "templateName", "enabled", "updatedAt"],
        "properties": {
          "automationId": { "type": "string" },
          "triggerEvent": { "type": "string" },
          "templateId": { "type": "string" },
          "templateName": { "type": "string" },
          "delayMinutes": { "type": "integer", "nullable": true },
          "enabled": { "type": "boolean" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "x-zod-schema": "AutomationResponse"
      },
      "CommunicationsLogResponse": {
        "type": "object",
        "required": ["communications", "total", "page", "limit"],
        "properties": {
          "communications": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["logId", "recipientEmail", "recipientName", "subject", "templateName", "triggerEvent", "deliveryStatus"],
              "properties": {
                "logId": { "type": "string" },
                "recipientEmail": { "type": "string" },
                "recipientName": { "type": "string" },
                "subject": { "type": "string" },
                "templateName": { "type": "string" },
                "triggerEvent": { "type": "string" },
                "deliveryStatus": { "type": "string", "enum": ["sent", "failed", "pending"] },
                "sentAt": { "type": "string", "format": "date-time", "nullable": true },
                "failureReason": { "type": "string", "nullable": true }
              }
            }
          },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "limit": { "type": "integer" }
        },
        "x-zod-schema": "CommunicationsLogResponse"
      },
      "RetryEmailResponse": {
        "type": "object",
        "required": ["logId", "message", "retryQueued"],
        "properties": {
          "logId": { "type": "string" },
          "message": { "type": "string" },
          "retryQueued": { "type": "boolean" }
        },
        "x-zod-schema": "RetryEmailResponse"
      },
      "AdminProfile": {
        "type": "object",
        "required": ["id", "email", "name", "role"],
        "properties": {
          "id": { "type": "string", "format": "cuid" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string" },
          "role": { "type": "string", "enum": ["admin"] }
