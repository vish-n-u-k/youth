  "tags": [
    { "name": "platform", "description": "Global platform endpoints (health, status)" },
    { "name": "auth_accounts", "description": "Authentication and account management" },
    { "name": "settings", "description": "Location settings and configuration" },
    { "name": "lead_management", "description": "Lead CRM and activity tracking" },
    { "name": "enrollment_trial", "description": "Trial booking and enrollment" },
    { "name": "program_pricing", "description": "Programs and coupon management" },
    { "name": "calendar_scheduling", "description": "Calendar date management" },
    { "name": "payment_tracking", "description": "Payment tracking and Zelle instructions" },
    { "name": "communication", "description": "Email templates, automations, and delivery logs" },
    { "name": "admin_dashboard", "description": "Dashboard metrics and widgets" }
