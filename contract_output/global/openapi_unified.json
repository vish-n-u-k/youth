  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session",
        "description": "Server-side session via httpOnly cookie. Cookie contains session ID; session validated against DB on every request."
      }
    },
    "schemas": {
      "ApiError": {
        "type": "object",
        "required": ["error", "message", "statusCode"],
        "properties": {
          "error": {
            "type": "string",
            "description": "Machine-readable error code",
            "enum": ["BAD_REQUEST", "VALIDATION_ERROR", "UNAUTHORIZED", "FORBIDDEN", "NOT_FOUND", "CONFLICT", "GONE", "TOO_MANY_REQUESTS", "INTERNAL_ERROR"]
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "statusCode": {
            "type": "integer",
            "description": "HTTP status code",
            "enum": [400, 401, 403, 404, 409, 410, 429, 500]
          },
          "details": {
            "type": "array",
            "description": "Field-level validation errors (present only for VALIDATION_ERROR)",
            "items": {
              "type": "object",
              "required": ["field", "message"],
              "properties": {
                "field": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        },
        "x-zod-schema": "ApiError"
      },
      "AdminLoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 }
        },
        "x-zod-schema": "AdminLoginRequest"
      },
      "AdminLoginResponse": {
        "type": "object",
        "required": ["user"],
        "properties": {
          "user": { "$ref": "#/components/schemas/AdminProfile" }
        },
        "x-zod-schema": "AdminLoginResponse"
      },
      "PasswordResetRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" }
        },
        "x-zod-schema": "PasswordResetRequest"
      },
      "SetNewPasswordRequest": {
        "type": "object",
        "required": ["token", "newPassword", "confirmPassword"],
        "properties": {
          "token": { "type": "string" },
          "newPassword": { "type": "string", "minLength": 8 },
          "confirmPassword": { "type": "string", "minLength": 8 }
        },
        "x-validation": "newPassword must equal confirmPassword",
        "x-zod-schema": "SetNewPasswordRequest"
      },
      "MessageResponse": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": { "type": "string" }
        }
      },
      "SettingsResponse": {
        "type": "object",
        "required": ["locationId", "businessName", "address", "phone", "email", "zelleRecipientName", "zelleContactInfo", "notifyNewLead", "notifyNewEnrollment", "notifyPaymentReceived"],
        "properties": {
          "locationId": { "type": "string" },
          "businessName": { "type": "string" },
          "address": { "type": "string" },
          "phone": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "websiteUrl": { "type": "string", "format": "uri", "nullable": true },
          "zelleRecipientName": { "type": "string" },
          "zelleContactInfo": { "type": "string" },
          "zelleInstructions": { "type": "string", "nullable": true },
          "notifyNewLead": { "type": "boolean" },
          "notifyNewEnrollment": { "type": "boolean" },
          "notifyPaymentReceived": { "type": "boolean" }
        },
        "x-zod-schema": "SettingsResponse"
      },
      "UpdateSettingsRequest": {
        "type": "object",
        "required": ["businessName", "address", "phone", "email", "zelleRecipientName", "zelleContactInfo", "notifyNewLead", "notifyNewEnrollment", "notifyPaymentReceived"],
        "properties": {
          "businessName": { "type": "string", "minLength": 1 },
          "address": { "type": "string", "minLength": 1 },
          "phone": { "type": "string", "minLength": 1 },
          "email": { "type": "string", "format": "email" },
          "websiteUrl": { "type": "string", "format": "uri" },
          "zelleRecipientName": { "type": "string", "minLength": 1 },
          "zelleContactInfo": { "type": "string", "minLength": 1 },
          "zelleInstructions": { "type": "string" },
          "notifyNewLead": { "type": "boolean" },
          "notifyNewEnrollment": { "type": "boolean" },
          "notifyPaymentReceived": { "type": "boolean" }
        },
        "x-zod-schema": "UpdateSettingsRequest"
      },
      "TemplateListResponse": {
        "type": "object",
        "required": ["templates"],
        "properties": {
          "templates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["templateId", "name", "subject", "isDefault", "updatedAt"],
              "properties": {
                "templateId": { "type": "string" },
                "name": { "type": "string" },
                "subject": { "type": "string" },
                "triggerEvent": { "type": "string", "nullable": true },
                "isDefault": { "type": "boolean" },
                "updatedAt": { "type": "string", "format": "date-time" }
              }
            }
          }
        },
        "x-zod-schema": "TemplateListResponse"
      },
      "TemplateResponse": {
        "type": "object",
        "required": ["templateId", "name", "subject", "body", "availableVariables", "isDefault", "createdAt", "updatedAt"],
        "properties": {
          "templateId": { "type": "string" },
          "name": { "type": "string" },
          "subject": { "type": "string" },
          "body": { "type": "string" },
          "availableVariables": { "type": "array", "items": { "type": "string" } },
          "isDefault": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "x-zod-schema": "TemplateResponse"
      },
      "TemplateRequest": {
        "type": "object",
        "required": ["name", "subject", "body"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "subject": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 }
        },
